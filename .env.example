# Environment Configuration Template
# Copy this file to .env for local development (never commit .env)

# Application Settings
APP_VERSION=1.0.0
APP_TITLE=Igor's App (Online Version)
APP_DEBUG=false

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_ERROR_REPORTING=false
ENABLE_AUTO_SAVE=true

# Storage Configuration
STORAGE_KEY=igorsAppData
MAX_STORAGE_SIZE=5242880

# API Configuration (if needed for future enhancements)
# API_ENDPOINT=https://api.example.com
# API_KEY=your_api_key_here
# API_TIMEOUT=30000

# Third-party Services (examples - uncomment if needed)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# FIREBASE_API_KEY=xxxxx
# FIREBASE_PROJECT_ID=xxxxx

# Performance Settings
CACHE_DURATION=3600000
LAZY_LOAD_ENABLED=true

# Security Settings
RATE_LIMIT_ENABLED=false
MAX_REQUESTS_PER_MINUTE=60

# Development Settings
MOCK_DATA_ENABLED=false
LOG_LEVEL=info